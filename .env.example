# ─── ANTHROPIC ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ─── GOOGLE (Calendar + Sheets) ───
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: https://your-domain.vercel.app/api/google-auth
# 4. Enable "Google Calendar API" and "Google Sheets API"
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# Get this by visiting /api/google-auth after setting the above two:
GOOGLE_REFRESH_TOKEN=1//xxxxx

# ─── ROKU BRIDGE (local network) ───
# Run roku-bridge/server.js on your home network, expose via tunnel
ROKU_BRIDGE_URL=https://your-bridge-tunnel.ngrok.io
ROKU_BRIDGE_KEY=your-secret-key
